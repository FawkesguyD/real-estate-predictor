@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_LEFT_RIGHT()

title C4 Component - Current MVP API and Valuation Runtime

Person(api_consumer, "API consumer", "Calls prediction endpoints directly.")
Person(investor, "Investor", "Uses the shortlist workflow through the MVP UI.")

System_Boundary(repo, "Real Estate MVP Platform") {
  Container(ui, "apps/ui", "React/Vite", "Investor UI for login, opportunities, and shortlist.")

  Container_Boundary(api_container, "apps/api") {
    Component(api_http, "FastAPI application", "apps/api/api.py", "Exposes HTTP routes and orchestrates runtime flows.")
    Component(auth_session, "Auth and session flow", "apps/api/api.py + apps/api/deps.py + shared/auth.py", "Validates credentials and resolves current user from session state.")
    Component(prediction_flow, "Prediction flow", "apps/api/api.py", "Handles /predict and /predict/batch requests.")
    Component(opportunities_flow, "Valuation and shortlist flow", "apps/api/api.py", "Backfills valuations and serves /opportunities and /shortlist.")
    Component(model_bundle_cache, "Model bundle cache", "apps/api.api:get_model_bundle()", "Caches a loaded model bundle for runtime reuse.")
  }

  Component(inference_module, "Inference module", "ml/model/inference.py", "Proxy valuation, ranking, FX conversion, and lightweight explainability.")
  Component(preprocessing_module, "Inference preprocessing", "ml/model/preprocessing.py", "Builds model-ready inference frames.")

  Container(artifacts_store, "ml/artifacts", "Joblib bundles", "Saved model bundles used by API and ML pipeline.")
  ContainerDb(postgres, "PostgreSQL", "users, listings, valuations, shortlist_items", "Operational database for auth and opportunity flows.")
}

Rel(api_consumer, prediction_flow, "Calls /predict and /predict/batch", "HTTP/JSON")
Rel(investor, ui, "Uses", "HTTPS")
Rel(ui, auth_session, "Calls /auth/*, /opportunities, /shortlist", "HTTP/JSON + cookie session")

Rel(api_http, auth_session, "Routes authenticated UI requests to")
Rel(api_http, prediction_flow, "Routes prediction requests to")
Rel(api_http, opportunities_flow, "Routes valuation and shortlist requests to")

Rel(prediction_flow, model_bundle_cache, "Gets loaded model bundle from")
Rel(opportunities_flow, model_bundle_cache, "Gets loaded model bundle from")
Rel(model_bundle_cache, artifacts_store, "Reads best_model.joblib from", "joblib")

Rel(prediction_flow, inference_module, "Invokes single and batch valuation in")
Rel(opportunities_flow, inference_module, "Backfills missing valuations via")
Rel(inference_module, preprocessing_module, "Builds inference feature frames through")

Rel(auth_session, postgres, "Reads users and session-backed data via SQLAlchemy")
Rel(opportunities_flow, postgres, "Reads listings and shortlist data, writes valuations")

SHOW_LEGEND()
@enduml

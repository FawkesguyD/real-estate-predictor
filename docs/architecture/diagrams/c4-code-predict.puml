@startuml
!includeurl https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml

LAYOUT_TOP_DOWN()

title C4 Code - POST /predict Flow (module/function level)

Person(api_client, "API client", "Submits a single prediction request.")

Container_Boundary(api_module, "apps/api/api.py") {
  Component(request_schema, "SinglePredictionRequest", "Pydantic schema", "Validates input payload for /predict.")
  Component(route_handler, "predict()", "FastAPI route handler", "Coordinates model access and response building.")
  Component(bundle_cache, "get_model_bundle()", "apps/api.api", "Returns cached LoadedModelBundle or loads it on first access.")
  Component(response_schema, "PredictionResponse", "Pydantic schema", "Serializes the HTTP response body.")
}

Container_Boundary(inference_module, "ml/model") {
  Component(bundle_reader, "load_model_bundle()", "ml/model/inference.py", "Deserializes joblib payload into LoadedModelBundle.")
  Component(predict_valuation, "predict_proxy_valuation_from_bundle()", "ml/model/inference.py", "Normalizes currency/FX inputs and builds the valuation payload.")
  Component(predict_price, "predict_expected_price_from_bundle()", "ml/model/inference.py", "Builds the raw proxy price prediction.")
  Component(feature_prep, "prepare_inference_frame()", "ml/model/preprocessing.py", "Transforms request features into a model-ready frame.")
  Component(model_predict, "_predict_frame()", "ml/model/inference.py", "Invokes bundle.model.predict(...) and post-processes output.")
  Component(explainer, "explain_prediction_from_bundle()", "ml/model/inference.py", "Adds top_factors and explanation_summary when requested.")
}

Container(artifacts_store, "ml/artifacts/best_model.joblib", "Joblib bundle", "Default runtime model artifact.")

Rel(api_client, request_schema, "Sends JSON matching")
Rel(request_schema, route_handler, "Validated payload is passed to")
Rel(route_handler, bundle_cache, "Requests loaded bundle from")
Rel(bundle_cache, bundle_reader, "Cold start only calls")
Rel(bundle_reader, artifacts_store, "Reads", "joblib")

Rel(route_handler, predict_valuation, "Calls")
Rel(predict_valuation, predict_price, "Delegates core price prediction to")
Rel(predict_price, feature_prep, "Builds model-ready frame with")
Rel(predict_price, model_predict, "Runs prediction through")
Rel(predict_valuation, explainer, "Optionally augments payload with")
Rel(route_handler, response_schema, "Builds HTTP response with")

SHOW_LEGEND()
@enduml
